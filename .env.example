# mini-NEXEN environment example
# Copy to .env and fill in values as needed.

# LLM provider: gemini or lmstudio
MINI_NEXEN_PROVIDER=gemini
MINI_NEXEN_MODEL=gemini-2.5-flash

# Gemini API keys (use one)
GEMINI_API_KEY=
GOOGLE_API_KEY=

# LM Studio (local) settings
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_API_KEY=

# Embeddings (optional overrides)
MINI_NEXEN_EMBED_PROVIDER=gemini
MINI_NEXEN_EMBED_MODEL=gemini-embedding-001
MINI_NEXEN_EMBED_BASE_URL=

# Web retrieval (optional)
BRAVE_SEARCH_API_KEY=
GOOGLE_PSE_API_KEY=
GOOGLE_PSE_CX=
TAVILY_API_KEY=
X_API_BEARER_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=mini-nexen/0.1

# Query review (optional)
# MINI_NEXEN_QUERY_EDITOR=code --wait

# Logging
MINI_NEXEN_VERBOSE=1
